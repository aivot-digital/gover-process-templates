    {
      "id": 81,
      "processId": 8,
      "processVersion": 1,
      "name": "Zustellung Bescheid",
      "description": "Zustellung des Erfolgsbescheides an die Antragsteller:in.",
      "dataKey": "bj5vg",
      "processNodeDefinitionKey": "de.aivot.core.mail",
      "processNodeDefinitionVersion": 1,
      "configuration": {
        "automatic_content": "Sehr geehrte(r) **{{ $.Person.Vorname }} {{ $.Person.Nachname }}**,\n\n\n\nim Anhang zu dieser E-Mail erhalten Sie Ihren offiziellen **Erfolgsbescheid** des Amts Bad Musterstadt im PDF-Format.\n\n**Kurzinfo zum Vorgang:**\n\n* **Status:** Erfolgreich abgeschlossen\n* **Empfänger:** {{ $.Person.Vorname }} {{ $.Person.Nachname }}\n* **Kontakt für Rückfragen:** [mail@aivot.de](mailto:mail@aivot.de)\n\nWir freuen uns, Ihnen mitteilen zu können, dass Ihr Anliegen positiv beschieden wurde. Bitte bewahren Sie das angehängte Dokument für Ihre Unterlagen auf.\n\n\n\nBei weiteren Fragen stehen wir Ihnen gerne zur Verfügung.\n\n\n\nMit freundlichen Grüßen\n\n**Ihr Team vom Amt Bad Musterstadt**",
        "automatic_subject": "Ihr Bescheid vom Amt Bad Musterstadt – Referenz: {{ $.Person.Nachname }}",
        "attachment_file_names": [
          "Erfolgsbescheid.pdf"
        ],
        "execution_type": "automatic",
        "to": "{{ $.Kontakt.EMailAdresse }}"
      },
      "outputMappings": {},
      "timeLimitDays": null,
      "requirements": null,
      "notes": null,
      "savedWithErrors": false
    },
    {
      "id": 85,
      "processId": 8,
      "processVersion": 1,
      "name": "Antragsteller:in informieren",
      "description": "Informiert die Antragsteller:in über die Ablehnung aufgrund von ungültigen Angaben.",
      "dataKey": "x3uQt",
      "processNodeDefinitionKey": "de.aivot.core.mail",
      "processNodeDefinitionVersion": 1,
      "configuration": {
        "automatic_content": "Sehr geehrte Antragsteller:in,\n\nleider konnte Ihr Antrag nicht verarbeitet werden, da Ihre Antragsdaten unvollständig waren.\nBitte kontaktieren Sie uns für das weitere Vorgehen.\n\n\n\nMit freundlichen Grüßen\n\nAmt Bad Musterstadt",
        "automatic_subject": "Unvollständige Daten",
        "execution_type": "automatic",
        "to": "{{ $.Kontakt.EMailAdresse }}"
      },
      "outputMappings": {},
      "timeLimitDays": null,
      "requirements": null,
      "notes": null,
      "savedWithErrors": false
    },
    {
      "id": 80,
      "processId": 8,
      "processVersion": 1,
      "name": "Bescheiderstellung",
      "description": "Erstellt den Erfolgsbescheid für die Antragsteller:in.",
      "dataKey": "S23xr",
      "processNodeDefinitionKey": "de.aivot.core.pdf",
      "processNodeDefinitionVersion": 1,
      "configuration": {
        "file_name": "Erfolgsbescheid.pdf",
        "content_html_code": "<html lang=\"de\">\n<head>\n    <meta charset=\"UTF-8\">\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            line-height: 1.6;\n            color: #333;\n            margin: 40px;\n        }\n        .header {\n            text-align: right;\n            border-bottom: 2px solid #0055aa;\n            padding-bottom: 10px;\n            margin-bottom: 30px;\n        }\n        .amt-name {\n            font-weight: bold;\n            font-size: 1.2em;\n            color: #0055aa;\n        }\n        .content {\n            margin-top: 20px;\n        }\n        .success-box {\n            background-color: #f0fdf4;\n            border: 1px solid #16a34a;\n            padding: 15px;\n            margin: 20px 0;\n        }\n        .footer {\n            margin-top: 50px;\n            font-size: 0.8em;\n            color: #666;\n            border-top: 1px solid #ccc;\n            padding-top: 10px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"header\">\n        <div class=\"amt-name\">Amt Bad Musterstadt</div>\n        <div>Abteilung für Bürgerangelegenheiten</div>\n    </div>\n\n    <div class=\"content\">\n        <p>Bad Musterstadt, den {{ _date_v1.formatDate(_date_v1.createDate(), 'dd.MM.yyyy') }}</p>\n        \n        <p>\n            <strong>An:</strong><br>\n            {{ $.Person.Vorname }} {{ $.Person.Nachname }}<br>\n            E-Mail: {{ $.Kontakt.EMailAdresse }}\n        </p>\n\n        <h2>Erfolgsbescheid</h2>\n\n        <p>Sehr geehrte(r) {{ $.Person.Vorname }} {{ $.Person.Nachname }},</p>\n\n        <div class=\"success-box\">\n            <strong>Antrag bewilligt:</strong> Hiermit bestätigen wir Ihnen, dass Ihr Anliegen erfolgreich bearbeitet wurde.\n        </div>\n\n        <p>\n            Alle erforderlichen Unterlagen wurden geprüft und entsprechen den behördlichen Anforderungen.\n            Weitere Schritte sind Ihrerseits aktuell nicht erforderlich.\n        </p>\n\n        <p>\n            Mit freundlichen Grüßen,<br>\n            Ihr Team vom Amt Bad Musterstadt\n        </p>\n    </div>\n\n    <div class=\"footer\">\n        Dies ist ein automatisch erstelltes Dokument und ohne Unterschrift gültig.\n    </div>\n</body>\n</html>",
        "content_html_source": "contentHtml"
      },
